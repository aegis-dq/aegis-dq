{
  "name": "aegis-dq",
  "displayName": "Aegis DQ",
  "description": "Syntax highlighting, autocomplete, snippets, and inline validation for Aegis DQ rule YAML files.",
  "version": "0.1.0",
  "publisher": "aegis-dq",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/aegis-dq/aegis-dq"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "data quality",
    "dbt",
    "duckdb",
    "bigquery",
    "validation",
    "yaml"
  ],
  "activationEvents": [
    "onLanguage:aegis-rules",
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "aegis-rules",
        "aliases": ["Aegis Rules", "aegis-rules"],
        "extensions": [".aegis.yaml", ".aegis.yml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aegis-rules",
        "scopeName": "source.aegis-rules",
        "path": "./syntaxes/aegis-rules.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.sql": "sql"
        }
      }
    ],
    "snippets": [
      {
        "language": "aegis-rules",
        "path": "./snippets/aegis-rules.code-snippets"
      },
      {
        "language": "yaml",
        "path": "./snippets/aegis-rules.code-snippets"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ["*.aegis.yaml", "*.aegis.yml", "rules.yaml", "rules.yml"],
        "url": "./schemas/aegis-rule.json"
      }
    ],
    "configuration": {
      "title": "Aegis DQ",
      "properties": {
        "aegisDQ.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run schema validation when a rules file is saved."
        },
        "aegisDQ.hoverDocs": {
          "type": "boolean",
          "default": true,
          "description": "Show hover documentation for rule types and severity values."
        }
      }
    },
    "commands": [
      {
        "command": "aegisDQ.validateFile",
        "title": "Aegis DQ: Validate Rule File"
      },
      {
        "command": "aegisDQ.insertSnippet",
        "title": "Aegis DQ: Insert Rule Template"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
